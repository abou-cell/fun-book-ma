generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  PROVIDER
  ADMIN
}

enum ProviderStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ActivityModerationStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  ONLINE_CARD
  CASH_ON_SITE
  PARTIAL_PAYMENT
}

enum PaymentProvider {
  MOCK_GATEWAY
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum ActivityCategory {
  ADVENTURE
  SURF
  WELLNESS
  KIDS
  CULTURE
  NATURE
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
  FAILED
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      UserRole  @default(CLIENT)
  provider  Provider?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Provider {
  id                      String         @id @default(cuid())
  userId                  String         @unique
  businessName            String
  city                    String
  description             String
  phone                   String?
  whatsapp                String?
  status                  ProviderStatus @default(PENDING)
  reviewedAt              DateTime?
  reviewedBy              String?
  rejectionReason         String?
  moderationNotes         String?
  commissionRate          Decimal        @default(0.10) @db.Decimal(5, 4)
  customCommissionEnabled Boolean        @default(false)
  user                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities              Activity[]
  payouts                 Payout[]
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([status, createdAt])
}

model Activity {
  id               String                   @id @default(cuid())
  providerId       String
  title            String
  slug             String                   @unique
  shortDescription String
  description      String
  city             String
  category         ActivityCategory
  price            Decimal                  @db.Decimal(10, 2)
  rating           Decimal                  @default(0) @db.Decimal(3, 2)
  reviewCount      Int                      @default(0)
  duration         String
  coverImage       String
  isActive         Boolean                  @default(true)
  status           ActivityModerationStatus @default(DRAFT)
  reviewedAt       DateTime?
  reviewedBy       String?
  rejectionReason  String?
  moderationNotes  String?
  provider         Provider                 @relation(fields: [providerId], references: [id], onDelete: Cascade)
  images           ActivityImage[]
  schedules        Schedule[]
  bookings         Booking[]
  createdAt        DateTime                 @default(now())
  translations     ActivityTranslation[]
  updatedAt        DateTime                 @updatedAt

  @@index([city, category])
  @@index([status, createdAt])
  @@index([isActive, createdAt])
}

model ActivityImage {
  id         String   @id @default(cuid())
  activityId String
  imageUrl   String
  altText    String?
  isCover    Boolean  @default(false)
  sortOrder  Int      @default(0)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([activityId, sortOrder])
}

model Schedule {
  id             String    @id @default(cuid())
  activityId     String
  date           DateTime
  startTime      DateTime
  endTime        DateTime
  capacity       Int
  availableSpots Int
  price          Decimal   @db.Decimal(10, 2)
  isActive       Boolean   @default(true)
  activity       Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([activityId, date, isActive])
}

model Booking {
  id                   String         @id @default(cuid())
  userId               String
  activityId           String
  scheduleId           String
  participants         Int
  totalPrice           Decimal        @db.Decimal(10, 2)
  subtotal             Decimal        @db.Decimal(10, 2)
  serviceFee           Decimal?       @db.Decimal(10, 2)
  commissionAmount     Decimal        @db.Decimal(10, 2)
  providerPayoutAmount Decimal        @db.Decimal(10, 2)
  paymentStatus        PaymentStatus  @default(UNPAID)
  paymentMethod        PaymentMethod?
  paymentReference     String?
  paidAt               DateTime?
  status               BookingStatus  @default(PENDING)
  customerName         String
  customerEmail        String
  customerPhone        String?
  notes                String?
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity             Activity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  schedule             Schedule       @relation(fields: [scheduleId], references: [id], onDelete: Restrict)
  payments             Payment[]
  refunds              Refund[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([userId, createdAt])
  @@index([activityId, createdAt])
  @@index([scheduleId])
  @@index([paymentStatus])
}

model Payment {
  id         String          @id @default(cuid())
  bookingId  String
  provider   PaymentProvider @default(MOCK_GATEWAY)
  amount     Decimal         @db.Decimal(10, 2)
  currency   String          @default("MAD")
  status     PaymentStatus
  reference  String?
  rawPayload Json?
  booking    Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([bookingId, createdAt])
}

model Payout {
  id          String       @id @default(cuid())
  providerId  String
  amount      Decimal      @db.Decimal(10, 2)
  currency    String       @default("MAD")
  periodStart DateTime
  periodEnd   DateTime
  status      PayoutStatus @default(PENDING)
  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([providerId, periodStart, periodEnd])
}

model Refund {
  id          String       @id @default(cuid())
  bookingId   String
  amount      Decimal      @db.Decimal(10, 2)
  status      RefundStatus @default(REQUESTED)
  reason      String
  requestedAt DateTime     @default(now())
  processedAt DateTime?
  processedBy String?
  notes       String?
  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status, requestedAt])
  @@index([bookingId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  translations CategoryTranslation[]
  updatedAt DateTime @updatedAt
}

model City {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  translations CityTranslation[]
  updatedAt DateTime @updatedAt
}

model PlatformSetting {
  id                        Int      @id @default(1)
  defaultLocale             String   @default("fr")
  enabledLocales            String[] @default(["fr", "ar", "en"])
  defaultCurrency           String   @default("MAD")
  supportWhatsappNumber     String?
  enabledPaymentMethods     PaymentMethod[] @default([ONLINE_CARD, CASH_ON_SITE])
  partialPaymentEnabled     Boolean  @default(false)
  depositPercentage         Decimal? @db.Decimal(5, 2)
  defaultCommissionRate     Decimal  @default(0.10) @db.Decimal(5, 4)
  supportedCurrencies       String[] @default(["MAD"])
  cancellationPolicyDefault String   @default("Free cancellation up to 24 hours before activity")
  emailNotificationsEnabled Boolean  @default(true)
  paymentOptionsEnabled     Boolean  @default(true)
  maintenanceModeEnabled    Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model AdminActionLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String
  notes       String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([entityType, entityId])
}


model ActivityTranslation {
  id               String   @id @default(cuid())
  activityId       String
  locale           String
  title            String
  shortDescription String
  description      String
  seoTitle         String?
  seoDescription   String?
  faq              Json?
  activity         Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, locale])
  @@index([locale])
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  locale     String
  name       String
  seoText    String?
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model CityTranslation {
  id         String @id @default(cuid())
  cityId     String
  locale     String
  name       String
  content    String?
  seoText    String?
  city       City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, locale])
}
