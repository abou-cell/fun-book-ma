# Runtime
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/funbook"

# Auth
AUTH_SECRET="replace-with-a-strong-random-secret-at-least-32-characters"

# Email
EMAIL_PROVIDER="mock"
EMAIL_FROM="noreply@funbook.local"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Storage
STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# Payments
PAYMENT_PROVIDER="mock"
PAYMENT_API_KEY=""
PAYMENT_WEBHOOK_SECRET=""
MOCK_PAYMENT_SUCCESS_RATE="0.85"

# Monitoring / logging / operations
MONITORING_DSN=""
APP_LOG_LEVEL="info"
MAINTENANCE_MODE="false"

# Public support channels
NEXT_PUBLIC_SUPPORT_WHATSAPP="+212600000000"
